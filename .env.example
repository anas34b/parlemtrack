# Base de données PostgreSQL (voir docker-compose.yml)
POSTGRES_PASSWORD=parlemtrack
DATABASE_URL=postgresql+psycopg2://parlemtrack:parlemtrack@localhost:5432/parlemtrack

# Cache Redis
REDIS_URL=redis://localhost:6380/0

# API Mistral La Plateforme
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Environnement d'exécution : dev | prod
ENV=dev

# Origines autorisées pour le CORS de l'API (liste JSON)
CORS_ORIGINS=["http://localhost:3000"]

# Durée de vie du cache Redis des réponses API, en secondes
CACHE_TTL_S=300

# Limite de requêtes par client sur l'API (format slowapi)
RATE_LIMIT=60/minute
